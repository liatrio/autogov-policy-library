{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "configMigration": true,
  "packageRules": [
    {
      "extends": [
        ":semanticPrefixFixDepsChoreOthers",
        "helpers:pinGitHubActionDigests"
      ],
      "matchDepTypes": [
        "action"
      ],
      "pinDigests": true,
      "groupName": "GitHub Actions",
      "groupSlug": "github-actions"
    }
  ],
  "customManagers": [
    {
      "customType": "regex",
      "managerFilePatterns": [
        "/\\.github/workflows/.*\\.yaml$/"
      ],
      "matchStrings": [
        "(?:https://github\\.com/|)liatrio/autogov-workflows/\\.github/workflows/.*?\\.yaml@(?<currentDigest>[a-f0-9]+) # v(?<currentValue>\\d+\\.\\d+\\.\\d+)"
      ],
      "depNameTemplate": "liatrio/autogov-workflows",
      "packageNameTemplate": "liatrio/autogov-workflows",
      "datasourceTemplate": "github-tags"
    },
    {
      "customType": "regex",
      "managerFilePatterns": [
        "/\\.github/workflows/.*\\.yaml$/"
      ],
      "matchStrings": [
        "autogov-version:\\s*(?<currentValue>v\\d+\\.\\d+\\.\\d+)"
      ],
      "depNameTemplate": "liatrio/autogov",
      "datasourceTemplate": "github-releases"
    }
  ],
  "schedule": [
    "before 5am every weekday"
  ],
  "labels": [
    "renovate",
    "gha"
  ]
}
