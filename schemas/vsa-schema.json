{
    "$schema": "http://json-schema.org/draft-07/schema#",
    "type": "object",
    "properties": {
        "_type": {
            "type": "string",
            "const": "https://in-toto.io/Statement/v1"
        },
        "subject": {
            "type": "array",
            "items": {
                "type": "object",
                "properties": {
                    "uri": {
                        "type": "string"
                    },
                    "digest": {
                        "type": "object",
                        "properties": {
                            "sha256": {
                                "type": "string"
                            }
                        },
                        "required": [
                            "sha256"
                        ]
                    }
                },
                "required": [
                    "uri",
                    "digest"
                ]
            }
        },
        "predicateType": {
            "type": "string",
            "const": "https://slsa.dev/verification_summary/v1"
        },
        "predicate": {
            "type": "object",
            "properties": {
                "verifier": {
                    "type": "object",
                    "properties": {
                        "id": {
                            "type": "string",
                            "format": "uri"
                        }
                    },
                    "required": [
                        "id"
                    ]
                },
                "timeVerified": {
                    "type": "string",
                    "format": "date-time"
                },
                "resourceUri": {
                    "type": "string"
                },
                "verificationResult": {
                    "type": "string",
                    "enum": [
                        "PASSED",
                        "FAILED",
                        "UNKNOWN"
                    ]
                },
                "verifiedLevels": {
                    "type": "array",
                    "items": {
                        "type": "string"
                    }
                }
            },
            "required": [
                "verifier",
                "timeVerified",
                "resourceUri",
                "verificationResult"
            ]
        }
    },
    "required": [
        "_type",
        "subject",
        "predicateType",
        "predicate"
    ]
}